generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContractType {
  SALE
  LEASE
  INSTALLMENT
  PPA_KWH
  HYBRID
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

enum SystemStatus {
  PLANNING
  INSTALLING
  ACTIVE
  MAINTENANCE
  WARNING
  FAULT
  OFFLINE
  INACTIVE
}

enum CustomerStatus {
  ACTIVE
  ONBOARDING
  ON_HOLD
  INACTIVE
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ContentPostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ContactInquiryStatus {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED
}

model Role {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String
  fullName     String
  phone        String?
  refreshToken String?
  roleId       String
  role         Role        @relation(fields: [roleId], references: [id])
  customer     Customer?   @relation("CustomerAccount")
  managedCustomers Customer[] @relation("CustomerOwner")
  uploadedMediaAssets MediaAsset[] @relation("MediaUploadedBy")
  updatedMonthlyEnergyRecords MonthlyEnergyRecord[] @relation("MonthlyEnergyUpdatedBy")
  aiActionDrafts AiActionDraft[] @relation("AiActionDraftCreatedBy")
  reviewedPayments Payment[] @relation("PaymentReviewedBy")
  notifications Notification[]
  auditLogs    AuditLog[]
  contentPosts ContentPost[]
  handledContactInquiries ContactInquiry[]
  updatedAiProviderConfigs AiProviderConfig[]
  updatedZaloProviderConfigs ZaloProviderConfig[] @relation("ZaloProviderConfigUpdatedBy")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?

  @@index([roleId])
  @@index([deletedAt])
}

model AiProviderConfig {
  id             String   @id @default(cuid())
  provider       String   @unique
  encryptedApiKey String?
  model          String?
  updatedByUserId String?
  updatedByUser  User?    @relation(fields: [updatedByUserId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  @@index([updatedByUserId])
  @@index([deletedAt])
}

model ZaloProviderConfig {
  id                   String   @id @default(cuid())
  provider             String   @unique
  appId                String?
  appSecretEncrypted   String?
  oaId                 String?
  accessTokenEncrypted String?
  refreshTokenEncrypted String?
  accessTokenExpiresAt DateTime?
  apiBaseUrl           String?
  templateInvoiceId    String?
  templateReminderId   String?
  templatePaidId       String?
  updatedByUserId      String?
  updatedByUser        User?    @relation("ZaloProviderConfigUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  lastTestedAt         DateTime?
  lastTestStatus       String?
  lastTestMessage      String?
  lastRefreshAt        DateTime?
  lastRefreshStatus    String?
  lastRefreshMessage   String?
  lastTokenCheckedAt   DateTime?
  lastTokenStatus      String?
  lastTokenMessage     String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  deletedAt            DateTime?

  @@index([updatedByUserId])
  @@index([deletedAt])
}

model Customer {
  id                  String          @id @default(cuid())
  userId              String          @unique
  user                User            @relation("CustomerAccount", fields: [userId], references: [id])
  customerCode        String          @unique
  companyName         String?
  installationAddress String?
  billingAddress      String?
  notes               String?
  defaultUnitPrice    Decimal?        @db.Decimal(12,2)
  defaultTaxAmount    Decimal?        @db.Decimal(12,2)
  defaultVatRate      Decimal?        @db.Decimal(5,2)
  defaultDiscountAmount Decimal?      @db.Decimal(12,2)
  status              CustomerStatus  @default(ACTIVE)
  ownerUserId         String?
  ownerUser           User?           @relation("CustomerOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  solarSystems        SolarSystem[]
  contracts           Contract[]
  invoices            Invoice[]
  payments            Payment[]
  zaloMessageLogs     ZaloMessageLog[]
  deyeConnections     DeyeConnection[]
  solarmanConnections SolarmanConnection[]
  monthlyEnergyRecords MonthlyEnergyRecord[]
  monthlyPvBillings   MonthlyPvBilling[]
  supportTickets      SupportTicket[]
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  deletedAt           DateTime?

  @@index([companyName])
  @@index([status])
  @@index([ownerUserId])
  @@index([deletedAt])
}

model SolarSystem {
  id                  String         @id @default(cuid())
  customerId          String?
  customer            Customer?      @relation(fields: [customerId], references: [id])
  systemCode          String         @unique
  name                String
  systemType          String?
  capacityKwp         Decimal        @db.Decimal(10,2)
  installedCapacityKwp Decimal?      @db.Decimal(10,2)
  panelCount          Int
  panelBrand          String?
  panelModel          String?
  inverterBrand       String?
  inverterModel       String?
  stationId           String?
  stationName         String?
  sourceSystem        String?
  hasBattery          Boolean?
  timeZone            String?
  locationAddress     String?
  latitude            Decimal?       @db.Decimal(10,6)
  longitude           Decimal?       @db.Decimal(10,6)
  gridInterconnectionType String?
  stationType         String?
  ownerName           String?
  startedAt           DateTime?
  externalPayload     Json?
  currentMonthGenerationKwh Decimal? @db.Decimal(12,2)
  currentYearGenerationKwh Decimal?  @db.Decimal(12,2)
  totalGenerationKwh  Decimal?       @db.Decimal(12,2)
  currentGenerationPowerKw Decimal?  @db.Decimal(12,2)
  defaultUnitPrice    Decimal?       @db.Decimal(12,2)
  defaultTaxAmount    Decimal?       @db.Decimal(12,2)
  defaultVatRate      Decimal?       @db.Decimal(5,2)
  defaultDiscountAmount Decimal?     @db.Decimal(12,2)
  deyeConnectionId    String?
  deyeConnection      DeyeConnection? @relation(fields: [deyeConnectionId], references: [id], onDelete: SetNull)
  solarmanConnectionId String?
  solarmanConnection  SolarmanConnection? @relation(fields: [solarmanConnectionId], references: [id], onDelete: SetNull)
  luxPowerConnection  LuxPowerConnection?
  monitoringProvider  String?
  monitoringPlantId   String?
  latestMonitorSnapshot Json?
  latestMonitorAt     DateTime?
  lastStationSyncAt   DateTime?
  lastRealtimeSyncAt  DateTime?
  lastDailySyncAt     DateTime?
  lastHourlySyncAt    DateTime?
  lastMonthlySyncAt   DateTime?
  lastBillingSyncAt   DateTime?
  installDate         DateTime?
  location            String?
  notes               String?
  metadata            Json?
  status              SystemStatus   @default(ACTIVE)
  contracts           Contract[]
  devices             Device[]
  deyeTelemetryRecords DeyeTelemetryRecord[]
  deyeDailyRecords    DeyeDailyRecord[]
  energyRecords       EnergyRecord[]
  monthlyEnergyRecords MonthlyEnergyRecord[]
  monthlyPvBillings   MonthlyPvBilling[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  deletedAt           DateTime?

  @@index([customerId])
  @@index([deyeConnectionId])
  @@index([solarmanConnectionId])
  @@index([monitoringPlantId])
  @@index([status])
  @@index([deletedAt])
  @@unique([sourceSystem, stationId])
}

model DeyeConnection {
  id                String               @id @default(cuid())
  accountName       String
  appId             String
  appSecretEncrypted String
  email             String
  passwordEncrypted String
  baseUrl           String
  accessToken       String?
  refreshToken      String?
  tokenType         String?
  expiresIn         Int?
  tokenExpiredAt    DateTime?
  uid               Int?
  companyId         Int?
  companyName       String?
  roleName          String?
  customerId        String?
  customer          Customer?            @relation(fields: [customerId], references: [id], onDelete: SetNull)
  status            String               @default("PENDING")
  lastSyncTime      DateTime?
  lastError         String?
  systems           SolarSystem[]
  devices           Device[]
  telemetryRecords  DeyeTelemetryRecord[]
  dailyRecords      DeyeDailyRecord[]
  monthlyEnergyRecords MonthlyEnergyRecord[]
  syncLogs          SyncLog[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  deletedAt         DateTime?

  @@index([customerId])
  @@index([status])
  @@index([deletedAt])
}

model DeyeTelemetryRecord {
  id                  String          @id @default(cuid())
  solarSystemId       String
  solarSystem         SolarSystem     @relation(fields: [solarSystemId], references: [id])
  deyeConnectionId    String?
  deyeConnection      DeyeConnection? @relation(fields: [deyeConnectionId], references: [id], onDelete: SetNull)
  stationId           String
  recordedAt          DateTime
  generationPowerKw   Decimal?        @db.Decimal(12,2)
  generationValueKwh  Decimal?        @db.Decimal(12,2)
  consumptionPowerKw  Decimal?        @db.Decimal(12,2)
  consumptionValueKwh Decimal?        @db.Decimal(12,2)
  purchasePowerKw     Decimal?        @db.Decimal(12,2)
  purchaseValueKwh    Decimal?        @db.Decimal(12,2)
  gridPowerKw         Decimal?        @db.Decimal(12,2)
  gridValueKwh        Decimal?        @db.Decimal(12,2)
  batteryPowerKw      Decimal?        @db.Decimal(12,2)
  batterySocPct       Decimal?        @db.Decimal(12,2)
  chargePowerKw       Decimal?        @db.Decimal(12,2)
  chargeValueKwh      Decimal?        @db.Decimal(12,2)
  dischargePowerKw    Decimal?        @db.Decimal(12,2)
  dischargeValueKwh   Decimal?        @db.Decimal(12,2)
  fullPowerHours      Decimal?        @db.Decimal(12,2)
  syncTime            DateTime
  rawPayload          Json?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  deletedAt           DateTime?

  @@unique([stationId, recordedAt])
  @@index([solarSystemId, recordedAt])
  @@index([deyeConnectionId, recordedAt])
  @@index([deletedAt])
}

model DeyeDailyRecord {
  id                  String          @id @default(cuid())
  solarSystemId       String
  solarSystem         SolarSystem     @relation(fields: [solarSystemId], references: [id])
  deyeConnectionId    String?
  deyeConnection      DeyeConnection? @relation(fields: [deyeConnectionId], references: [id], onDelete: SetNull)
  stationId           String
  recordDate          DateTime
  generationValueKwh  Decimal?        @db.Decimal(12,2)
  consumptionValueKwh Decimal?        @db.Decimal(12,2)
  purchaseValueKwh    Decimal?        @db.Decimal(12,2)
  gridValueKwh        Decimal?        @db.Decimal(12,2)
  batterySocPct       Decimal?        @db.Decimal(12,2)
  fullPowerHours      Decimal?        @db.Decimal(12,2)
  syncTime            DateTime
  rawPayload          Json?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  deletedAt           DateTime?

  @@unique([stationId, recordDate])
  @@index([solarSystemId, recordDate])
  @@index([deyeConnectionId, recordDate])
  @@index([deletedAt])
}

model Device {
  id               String          @id @default(cuid())
  systemId         String
  system           SolarSystem     @relation(fields: [systemId], references: [id])
  connectionId     String?
  connection       DeyeConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  stationId        String
  deviceId         String?
  deviceSn         String
  deviceType       String
  productId        String?
  connectStatus    String?
  collectionTime   BigInt?
  externalPayload  Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  deletedAt        DateTime?

  @@unique([stationId, deviceSn])
  @@index([systemId])
  @@index([connectionId])
  @@index([stationId])
  @@index([deletedAt])
}

model SolarmanConnection {
  id                   String              @id @default(cuid())
  accountName          String
  usernameOrEmail      String
  passwordEncrypted    String
  accessToken          String?
  refreshToken         String?
  cookieJar            Json?
  customerId           String?
  customer             Customer?           @relation(fields: [customerId], references: [id], onDelete: SetNull)
  defaultUnitPrice     Decimal?            @db.Decimal(12,2)
  defaultTaxAmount     Decimal?            @db.Decimal(12,2)
  defaultVatRate       Decimal?            @db.Decimal(5,2)
  defaultDiscountAmount Decimal?           @db.Decimal(12,2)
  status               String              @default("ACTIVE")
  lastSyncTime         DateTime?
  notes                String?
  systems              SolarSystem[]
  monthlyEnergyRecords MonthlyEnergyRecord[]
  syncLogs             SolarmanSyncLog[]
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  deletedAt            DateTime?

  @@index([customerId])
  @@index([status])
  @@index([deletedAt])
}

model LuxPowerConnection {
  id                    String           @id @default(cuid())
  accountName           String
  username              String?
  passwordEncrypted     String?
  plantId               String?
  inverterSerial        String?
  solarSystemId         String?          @unique
  solarSystem           SolarSystem?     @relation(fields: [solarSystemId], references: [id], onDelete: SetNull)
  pollingIntervalMinutes Int             @default(60)
  useDemoMode           Boolean          @default(false)
  status                String           @default("PENDING")
  lastLoginAt           DateTime?
  lastSyncTime          DateTime?
  lastError             String?
  lastProviderResponse  Json?
  notes                 String?
  syncLogs              LuxPowerSyncLog[]
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  deletedAt             DateTime?

  @@index([solarSystemId])
  @@index([status])
  @@index([deletedAt])
}

model LuxPowerSyncLog {
  id              String             @id @default(cuid())
  connectionId    String
  connection      LuxPowerConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  action          String
  status          String
  message         String
  providerCode    String?
  context         Json?
  responsePayload Json?
  startedAt       DateTime           @default(now())
  finishedAt      DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([connectionId, createdAt])
  @@index([status, createdAt])
}

model MonthlyEnergyRecord {
  id              String             @id @default(cuid())
  solarSystemId   String
  solarSystem     SolarSystem        @relation(fields: [solarSystemId], references: [id])
  customerId      String?
  customer        Customer?          @relation(fields: [customerId], references: [id])
  deyeConnectionId String?
  deyeConnection  DeyeConnection?    @relation(fields: [deyeConnectionId], references: [id], onDelete: SetNull)
  connectionId    String?
  connection      SolarmanConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  stationId       String
  year            Int
  month           Int
  pvGenerationKwh Decimal            @db.Decimal(12,2)
  loadConsumedKwh Decimal?           @db.Decimal(12,2)
  meterReadingStart Decimal?         @db.Decimal(14,2)
  meterReadingEnd Decimal?           @db.Decimal(14,2)
  savingsAmount   Decimal?           @db.Decimal(12,2)
  unitPrice       Decimal            @db.Decimal(12,2)
  subtotalAmount  Decimal            @db.Decimal(12,2)
  vatRate         Decimal            @default(0) @db.Decimal(5,2)
  taxAmount       Decimal            @default(0) @db.Decimal(12,2)
  discountAmount  Decimal            @default(0) @db.Decimal(12,2)
  totalAmount     Decimal            @db.Decimal(12,2)
  systemStatusSnapshot SystemStatus?
  updatedByUserId String?
  updatedByUser   User?              @relation("MonthlyEnergyUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  source          String
  syncTime        DateTime
  rawPayload      Json?
  note            String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?

  @@unique([solarSystemId, year, month])
  @@unique([source, stationId, year, month])
  @@index([stationId, year, month])
  @@index([customerId, year, month])
  @@index([deyeConnectionId])
  @@index([connectionId])
  @@index([updatedByUserId])
  @@index([deletedAt])
}

model AiActionDraft {
  id              String   @id @default(cuid())
  actionType      String
  title           String
  prompt          String?
  content         String
  targetType      String?
  targetId        String?
  status          String   @default("DRAFT")
  metadata        Json?
  createdByUserId String?
  createdByUser   User?    @relation("AiActionDraftCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  appliedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  @@index([actionType, status])
  @@index([createdByUserId])
  @@index([targetType, targetId])
  @@index([deletedAt])
}

model SyncLog {
  id              String          @id @default(cuid())
  source          String
  connectionId    String?
  connection      DeyeConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  syncType        String
  targetStationId String?
  status          String
  message         String?
  startedAt       DateTime        @default(now())
  finishedAt      DateTime?
  rawPayload      Json?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([source, createdAt])
  @@index([connectionId, createdAt])
  @@index([status])
  @@index([syncType])
  @@index([targetStationId])
}

model SolarmanSyncLog {
  id             String             @id @default(cuid())
  connectionId   String
  connection     SolarmanConnection @relation(fields: [connectionId], references: [id])
  action         String
  status         String
  message        String
  context        Json?
  syncedStations Int                @default(0)
  syncedMonths   Int                @default(0)
  syncedBillings Int                @default(0)
  startedAt      DateTime           @default(now())
  finishedAt     DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([connectionId, createdAt])
  @@index([status])
}

model MediaAsset {
  id               String   @id @default(cuid())
  filename         String
  originalName     String
  mimeType         String
  sizeBytes        Int
  storagePath      String
  title            String?
  description      String?
  altText          String?
  tags             String[] @default([])
  folder           String?
  uploadedByUserId String?
  uploadedByUser   User?    @relation("MediaUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  @@index([folder])
  @@index([uploadedByUserId])
  @@index([createdAt])
  @@index([deletedAt])
}

model ServicePackage {
  id                   String        @id @default(cuid())
  packageCode          String        @unique
  name                 String
  contractType         ContractType
  shortDescription     String?
  pricePerKwh          Decimal?      @db.Decimal(12,2)
  fixedMonthlyFee      Decimal?      @db.Decimal(12,2)
  maintenanceFee       Decimal?      @db.Decimal(12,2)
  annualEscalationRate Decimal?      @db.Decimal(5,2)
  vatRate              Decimal?      @db.Decimal(5,2)
  lateFeeRate          Decimal?      @db.Decimal(5,2)
  earlyDiscountRate    Decimal?      @db.Decimal(5,2)
  defaultTermMonths    Int?
  billingRule          String?
  notes                String?
  isActive             Boolean       @default(true)
  contracts            Contract[]
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  deletedAt            DateTime?

  @@index([packageCode])
  @@index([contractType])
  @@index([isActive])
  @@index([deletedAt])
}

model Contract {
  id               String         @id @default(cuid())
  customerId       String
  customer         Customer       @relation(fields: [customerId], references: [id])
  solarSystemId    String
  solarSystem      SolarSystem    @relation(fields: [solarSystemId], references: [id])
  servicePackageId String
  servicePackage   ServicePackage @relation(fields: [servicePackageId], references: [id])
  contractNumber   String         @unique
  type             ContractType
  status           ContractStatus @default(ACTIVE)
  startDate        DateTime
  endDate          DateTime?
  termMonths       Int?
  pricePerKwh      Decimal?       @db.Decimal(12,2)
  fixedMonthlyFee  Decimal?       @db.Decimal(12,2)
  interestRate     Decimal?       @db.Decimal(5,2)
  vatRate          Decimal?       @db.Decimal(5,2)
  contractFileUrl  String?
  invoices         Invoice[]
  monthlyPvBillings MonthlyPvBilling[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?

  @@index([customerId])
  @@index([solarSystemId])
  @@index([servicePackageId])
  @@index([status])
  @@index([deletedAt])
}

model EnergyRecord {
  id                String      @id @default(cuid())
  solarSystemId     String
  solarSystem       SolarSystem @relation(fields: [solarSystemId], references: [id])
  recordDate        DateTime
  solarGeneratedKwh Decimal     @db.Decimal(12,2)
  loadConsumedKwh   Decimal     @db.Decimal(12,2)
  gridImportedKwh   Decimal     @db.Decimal(12,2)
  gridExportedKwh   Decimal     @db.Decimal(12,2)
  selfConsumedKwh   Decimal     @db.Decimal(12,2)
  savingAmount      Decimal?    @db.Decimal(12,2)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@unique([solarSystemId, recordDate])
  @@index([recordDate])
}

model MonthlyPvBilling {
  id              String      @id @default(cuid())
  solarSystemId   String
  solarSystem     SolarSystem @relation(fields: [solarSystemId], references: [id])
  customerId      String
  customer        Customer    @relation(fields: [customerId], references: [id])
  contractId      String?
  contract        Contract?   @relation(fields: [contractId], references: [id], onDelete: SetNull)
  invoiceId       String?     @unique
  invoice         Invoice?    @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  month           Int
  year            Int
  pvGenerationKwh Decimal     @db.Decimal(12,2)
  billableKwh     Decimal     @db.Decimal(12,2)
  unitPrice       Decimal     @db.Decimal(12,2)
  subtotalAmount  Decimal     @db.Decimal(12,2)
  vatRate         Decimal     @default(0) @db.Decimal(5,2)
  taxAmount       Decimal     @default(0) @db.Decimal(12,2)
  discountAmount  Decimal     @default(0) @db.Decimal(12,2)
  totalAmount     Decimal     @db.Decimal(12,2)
  syncTime        DateTime
  source          String
  note            String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  @@unique([solarSystemId, month, year])
  @@index([customerId, year, month])
  @@index([contractId])
  @@index([deletedAt])
}

model Invoice {
  id             String        @id @default(cuid())
  customerId     String
  customer       Customer      @relation(fields: [customerId], references: [id])
  contractId     String
  contract       Contract      @relation(fields: [contractId], references: [id])
  invoiceNumber  String        @unique
  billingMonth   Int
  billingYear    Int
  issuedAt       DateTime
  dueDate        DateTime
  subtotal       Decimal       @db.Decimal(12,2)
  vatRate        Decimal       @default(0) @db.Decimal(5,2)
  vatAmount      Decimal       @db.Decimal(12,2)
  penaltyAmount  Decimal       @db.Decimal(12,2)
  discountAmount Decimal       @db.Decimal(12,2)
  totalAmount    Decimal       @db.Decimal(12,2)
  paidAmount     Decimal       @default(0) @db.Decimal(12,2)
  status         InvoiceStatus @default(ISSUED)
  items          InvoiceItem[]
  payments       Payment[]
  monthlyPvBilling MonthlyPvBilling?
  zaloMessageLogs ZaloMessageLog[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  @@index([customerId])
  @@index([contractId])
  @@index([status])
  @@index([billingYear, billingMonth])
  @@index([deletedAt])
}

model ZaloMessageLog {
  id              String    @id @default(cuid())
  invoiceId       String?
  invoice         Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName    String
  recipientPhone  String
  templateType    String
  templateId      String?
  sendStatus      String
  providerCode    String?
  providerMessage String?
  dryRun          Boolean   @default(false)
  requestPayload  Json?
  responsePayload Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@index([invoiceId, createdAt])
  @@index([customerId, createdAt])
  @@index([sendStatus, createdAt])
  @@index([templateType])
  @@index([deletedAt])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id])
  description String
  quantity    Decimal  @db.Decimal(12,2)
  unitPrice   Decimal  @db.Decimal(12,2)
  amount      Decimal  @db.Decimal(12,2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([invoiceId])
}

model Payment {
  id          String        @id @default(cuid())
  customerId  String
  customer    Customer      @relation(fields: [customerId], references: [id])
  invoiceId   String
  invoice     Invoice       @relation(fields: [invoiceId], references: [id])
  paymentCode String        @unique
  gateway     String
  method      String
  amount      Decimal       @db.Decimal(12,2)
  status      PaymentStatus @default(PENDING)
  paidAt      DateTime?
  proofStoragePath String?
  proofOriginalName String?
  proofMimeType String?
  referenceNote String?
  reviewNote  String?
  reviewedAt  DateTime?
  reviewedByUserId String?
  reviewedByUser User?      @relation("PaymentReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  metadata    Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([customerId])
  @@index([invoiceId])
  @@index([status])
  @@index([reviewedByUserId])
}

model SupportTicket {
  id          String          @id @default(cuid())
  customerId  String
  customer    Customer        @relation(fields: [customerId], references: [id])
  title       String
  description String
  status      TicketStatus    @default(OPEN)
  priority    TicketPriority  @default(MEDIUM)
  messages    TicketMessage[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  @@index([customerId])
  @@index([status])
  @@index([deletedAt])
}

model TicketMessage {
  id         String        @id @default(cuid())
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id])
  senderName String
  senderRole String
  message    String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([ticketId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  body      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([isRead])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String
  entityType String
  entityId   String?
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityType])
  @@index([createdAt])
}

model FeaturePlugin {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String
  category    String
  version     String   @default("1.0.0")
  installed   Boolean  @default(true)
  enabled     Boolean  @default(true)
  editable    Boolean  @default(true)
  isCore      Boolean  @default(false)
  routePath   String?
  areas       String[] @default([])
  sortOrder   Int      @default(0)
  config      Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([category])
  @@index([enabled, installed])
  @@index([deletedAt])
}

model ContentPost {
  id            String            @id @default(cuid())
  authorId      String
  author        User              @relation(fields: [authorId], references: [id])
  title         String
  slug          String            @unique
  excerpt       String?
  content       String
  coverImageUrl String?
  tags          String[]          @default([])
  status        ContentPostStatus @default(DRAFT)
  isFeatured    Boolean           @default(false)
  publishedAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?

  @@index([authorId])
  @@index([status, publishedAt])
  @@index([deletedAt])
}

model MarketingPage {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  published   Boolean  @default(true)
  sortOrder   Int      @default(0)
  content     Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([published])
  @@index([sortOrder])
  @@index([deletedAt])
}

model WebsiteSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  content     Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([deletedAt])
}

model ContactInquiry {
  id              String               @id @default(cuid())
  fullName        String
  email           String
  phone           String?
  companyName     String?
  siteCount       String?
  message         String
  sourcePage      String               @default("contact")
  status          ContactInquiryStatus @default(NEW)
  internalNote    String?
  handledByUserId String?
  handledBy       User?                @relation(fields: [handledByUserId], references: [id])
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  deletedAt       DateTime?

  @@index([email])
  @@index([status])
  @@index([handledByUserId])
  @@index([createdAt])
  @@index([deletedAt])
}
